# Database
DB_USER=innovation_user
DB_PASSWORD=innovation_pass
DB_NAME=innovation_hub
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://innovation_user:innovation_pass@localhost:5432/innovation_hub

# Redis
REDIS_URL=redis://localhost:6379
